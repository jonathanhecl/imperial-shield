<Window x:Class="ImperialShield.Views.SecurityWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALERTA DE SEGURIDAD - Imperial Shield" 
        Width="650" Height="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Storyboard x:Key="PulseIcon">
            <DoubleAnimation Storyboard.TargetName="AlertIcon" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1.0" To="1.2" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="AlertIcon" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1.0" To="1.2" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseIcon}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="30" Background="#060D18" BorderBrush="#E74C3C" BorderThickness="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="80" ShadowDepth="0" Color="#E74C3C" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <!-- Background Grid -->
            <Border Opacity="0.08" Margin="4">
                <Border.Background>
                    <VisualBrush TileMode="Tile" Viewport="0,0,60,60" ViewportUnits="Absolute">
                        <VisualBrush.Visual>
                            <Path Data="M0,0 L60,0 M0,0 L0,60" Stroke="#E74C3C" StrokeThickness="0.8" StrokeDashArray="4,4"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.Background>
            </Border>
            <!-- Center Glow -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.4" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#1A0508" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Alert Icon -->
            <Image x:Name="AlertIcon" Source="/Resources/shield_alert_icon.png" 
                   Width="100" Height="100" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,15">
                <Image.RenderTransform>
                    <ScaleTransform CenterX="50" CenterY="50"/>
                </Image.RenderTransform>
                <Image.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#E74C3C" Opacity="0.9"/>
                </Image.Effect>
            </Image>
            
            <!-- Title -->
            <TextBlock Grid.Row="1" Text="¡MODIFICACIÓN DEL SISTEMA DETECTADA!" 
                       Foreground="#E74C3C" 
                       FontWeight="ExtraBold" FontSize="26" 
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,10">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="2" Color="Black" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Details -->
            <ScrollViewer Grid.Row="2" Margin="0,10" VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock x:Name="WarningDesc" Text="Se ha detectado una redirección de ejecutable (IFEO) no autorizada." 
                               Foreground="#94A3B8" FontSize="15" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    
                    <Border Background="#16202C" CornerRadius="10" Padding="15" BorderBrush="#3A5F82" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Ejecutable afectado:" Foreground="White" FontSize="12" Opacity="0.7"/>
                            <TextBlock x:Name="TargetExeText" Text="chrome.exe" Foreground="#4DA8DA" FontSize="18" FontWeight="Bold" Margin="0,2,0,10" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                            
                            <TextBlock Text="Redirigido a (Debugger):" Foreground="White" FontSize="12" Opacity="0.7"/>
                            <TextBlock x:Name="DebuggerPathText" Text="C:\Windows\temp\virus.exe" 
                                       Foreground="#E74C3C" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"
                                       ToolTipService.InitialShowDelay="0"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                       Cursor="Hand">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Abrir ubicación del archivo" Click="OpenDebuggerLocation_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="⚠️ Esto significa que cada vez que intentes abrir el programa afectado, se ejecutará el segundo archivo en su lugar." 
                               Foreground="#F39C12" FontSize="11" Margin="0,20,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Actions -->
            <StackPanel Grid.Row="3" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="ActionButton" Content="ELIMINAR REDIRECCIÓN" Click="Action_Click" 
                        Width="420" Height="55" Margin="0,0,0,10"
                        FontSize="18" FontWeight="Bold"
                        Style="{StaticResource DangerButton}" Cursor="Hand"/>
                
                <Button Content="IGNORAR" Click="Ignore_Click" 
                        Width="420" Height="55" 
                        FontSize="16" FontWeight="Bold"
                        Background="Transparent" Foreground="#94A3B8" 
                        BorderThickness="1" BorderBrush="#3A5F82" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Border>
</Window>
