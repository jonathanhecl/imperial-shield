<Window x:Class="ImperialShield.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Imperial Shield"
        Width="520" Height="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Shield Pulse Animation -->
        <Storyboard x:Key="ShieldPulseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShieldImage" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1.0" To="1.15" Duration="0:0:1.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ShieldImage" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1.0" To="1.15" Duration="0:0:1.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ShieldGlow" Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1.0" Duration="0:0:1.8" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Progress Bar Glow Pulse -->
        <Storyboard x:Key="ProgressGlowAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ProgressBarGlow" Storyboard.TargetProperty="BlurRadius"
                             From="6" To="18" Duration="0:0:1.5" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource ShieldPulseAnim}"/>
            <BeginStoryboard Storyboard="{StaticResource ProgressGlowAnim}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="24" Background="#060D18" BorderBrush="#1A3A5A" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.9" Color="#000"/>
        </Border.Effect>

        <Grid>
            <!-- Background Grid Pattern -->
            <Border Opacity="0.08">
                <Border.Background>
                    <VisualBrush TileMode="Tile" Viewport="0,0,60,60" ViewportUnits="Absolute">
                        <VisualBrush.Visual>
                            <Path Data="M0,0 L60,0 M0,0 L0,60 M0,0 L60,60" Stroke="#4DA8DA" StrokeThickness="0.6" StrokeDashArray="3,3"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.Background>
            </Border>

            <!-- Clean Center Glow -->
            <Border>
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.35" RadiusX="0.6" RadiusY="0.6">
                        <GradientStop Color="#0A1A2E" Offset="0"/>
                        <GradientStop Color="#060D18" Offset="0.7"/>
                        <GradientStop Color="#040A12" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Top Accent Line -->
            <Border Height="3" VerticalAlignment="Top" Margin="24,0,24,0" CornerRadius="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#4DA8DA" Offset="0.3"/>
                        <GradientStop Color="#FFD700" Offset="0.5"/>
                        <GradientStop Color="#4DA8DA" Offset="0.7"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#4DA8DA" Opacity="0.8"/>
                </Border.Effect>
            </Border>

            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Shield Logo with Intense Glow -->
                <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Outer Aura -->
                    <Ellipse Width="220" Height="220" Fill="#001A33" Opacity="0.3">
                        <Ellipse.Effect>
                            <BlurEffect Radius="40"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <!-- Glow Ring -->
                    <Ellipse Width="180" Height="180" Stroke="#4DA8DA" StrokeThickness="1" Opacity="0.2">
                        <Ellipse.Effect>
                            <BlurEffect Radius="8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <!-- Shield Image -->
                    <Border x:Name="ShieldGlow" Opacity="0.7">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="35" ShadowDepth="0" Color="#4DA8DA" Opacity="1"/>
                        </Border.Effect>
                        <Image x:Name="ShieldImage" Source="/Resources/shield.png"
                               Width="160" Height="160"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform/>
                            </Image.RenderTransform>
                        </Image>
                    </Border>
                </Grid>

                <!-- Title with Neon Effect -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <TextBlock FontSize="36" FontWeight="ExtraBold" HorizontalAlignment="Center">
                        <Run Text="IMPERIAL" Foreground="#4DA8DA"/>
                        <Run Text=" SHIELD" Foreground="White"/>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#4DA8DA" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="⚔️ Sistema de Seguridad Avanzado ⚔️"
                               FontSize="14" Foreground="#94A3B8"
                               HorizontalAlignment="Center" Margin="0,6,0,0"
                               FontStyle="Italic" FontWeight="SemiBold">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#4DA8DA" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- RPG Progress Bar -->
                <Grid Grid.Row="2" Width="350" Height="10" Margin="0,25,0,0">
                    <Border Background="#0A1525" CornerRadius="5" BorderBrush="#1A3A5A" BorderThickness="1"/>
                    <Border x:Name="ProgressBarFill" Background="#4DA8DA" CornerRadius="5" Width="0" HorizontalAlignment="Left">
                        <Border.Effect>
                            <DropShadowEffect x:Name="ProgressBarGlow" BlurRadius="12" ShadowDepth="0" Color="#4DA8DA" Opacity="0.9"/>
                        </Border.Effect>
                    </Border>
                    <!-- Gold accent tip -->
                    <Border Width="2" Background="#FFD700" CornerRadius="1" HorizontalAlignment="Left" Margin="0,0,0,0"
                            x:Name="ProgressBarTip" Opacity="0"/>
                </Grid>

                <!-- Loading Status -->
                <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <TextBlock x:Name="StatusText"
                               Text="INICIALIZANDO SISTEMAS DE DEFENSA..."
                               FontSize="11" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="#4DA8DA" HorizontalAlignment="Center"
                               >
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4DA8DA" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <!-- Version -->
                <TextBlock Grid.Row="4"
                           x:Name="VersionText"
                           Text="v1.0.0.0"
                           FontSize="11"
                           FontWeight="Bold"
                           FontFamily="Consolas"
                           Foreground="#1A3A5A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,20,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
